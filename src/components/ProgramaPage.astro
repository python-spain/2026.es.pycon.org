---
import { programaTexts } from '@/i18n/programa'
import { menuTexts } from '@/i18n/menu'
import { getSchedule } from '@/lib/schedule'
import ScheduleList from '@/components/ScheduleList.astro'

interface Props {
  lang: string
}
const { lang } = Astro.props
const t = programaTexts[lang as keyof typeof programaTexts]
const menuT = menuTexts[lang as keyof typeof menuTexts]

// Fetch the schedule at build time. If Pretalx is down or the event isn't
// published yet, this returns null and we render the fallback message.
const schedule = await getSchedule()
---

<section class="py-8" aria-labelledby="schedule-title">
  <h1 id="schedule-title" class="text-3xl md:text-5xl font-bold text-center mb-6">{t.title}</h1>
  <p class="text-center text-base md:text-lg mb-10 max-w-2xl mx-auto opacity-80">{t.intro}</p>

  <fieldset
    class="schedule-view-toggle max-w-3xl mx-auto mb-8 border border-white/10 rounded-xl p-3 flex flex-wrap items-center gap-2 bg-pycon-black/40"
  >
    <legend class="sr-only">{t.list.viewModeLegend}</legend>
    <span
      aria-hidden="true"
      class="text-xs uppercase tracking-wider text-pycon-gray-25/70 px-2 font-semibold"
    >
      {t.list.viewModeLegend}
    </span>
    <label
      class="cursor-pointer px-4 py-2 rounded-lg text-sm has-[:checked]:bg-pycon-orange has-[:checked]:text-pycon-black has-[:checked]:font-semibold text-pycon-gray-25 transition-colors"
    >
      <input type="radio" name="schedule-view" value="list" class="sr-only" />
      {t.list.viewModeList}
    </label>
    <label
      class="cursor-pointer px-4 py-2 rounded-lg text-sm has-[:checked]:bg-pycon-orange has-[:checked]:text-pycon-black has-[:checked]:font-semibold text-pycon-gray-25 transition-colors"
    >
      <input type="radio" name="schedule-view" value="grid" class="sr-only" checked />
      {t.list.viewModeGrid}
    </label>
  </fieldset>

  <div id="schedule-list-view" class="schedule-view hidden" data-view="list">
    {
      schedule ? (
        <>
          <div class="max-w-3xl mx-auto mb-6 flex justify-end">
            <button
              type="button"
              class="favorites-filter-btn inline-flex items-center gap-2 px-4 py-2 rounded-lg border border-white/10 text-sm text-pycon-gray-25 hover:border-pycon-orange/50 hover:text-pycon-orange transition-colors focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-pycon-yellow has-[:checked]:bg-pycon-orange has-[:checked]:text-pycon-black has-[:checked]:font-semibold has-[:checked]:border-pycon-orange"
              aria-pressed="false"
              data-filter-favorites
            >
              <svg
                class="w-4 h-4"
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="2"
                aria-hidden="true"
              >
                <path
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z"
                />
              </svg>
              <span>
                {t.list.favoritesOnly} (<span data-favorites-count>0</span>)
              </span>
            </button>
          </div>
          <ScheduleList schedule={schedule} lang={lang} />
          <p
            class="favorites-empty max-w-3xl mx-auto mt-4 text-center text-pycon-gray-25/80 text-sm"
            data-favorites-empty
            hidden
          >
            {t.list.noFavorites}
          </p>
        </>
      ) : (
        <div class="max-w-2xl mx-auto text-center py-12 px-6 bg-pycon-black/40 rounded-2xl border border-white/5">
          <h2 class="text-2xl font-bold text-white mb-4">{t.list.emptyTitle}</h2>
          <p class="text-pycon-gray-25 mb-6">{t.list.emptyBody}</p>
          <a
            href="https://pretalx.com/pycones-2026/schedule/"
            target="_blank"
            rel="noopener noreferrer"
            aria-label={`${t.list.emptyCta} ${menuT.new_tab}`}
            class="inline-flex items-center gap-2 px-5 py-2.5 bg-pycon-orange text-pycon-black font-semibold rounded-lg hover:opacity-90 transition-opacity focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-pycon-yellow"
          >
            {t.list.emptyCta}
          </a>
        </div>
      )
    }
  </div>

  <div id="schedule-grid-view" class="schedule-view" data-view="grid">
    <pretalx-schedule
      event-url="https://pretalx.com/pycones-2026/"
      locale={t.locale}
      format="grid"
      style="--pretalx-clr-primary: #03004b; --pretalx-clr-success: #2e7d32; color-scheme: light"
    ></pretalx-schedule>

    <div id="schedule-status" role="status" aria-live="polite" aria-atomic="true" class="sr-only"></div>

    <script is:inline type="application/json" id="schedule-i18n" set:html={JSON.stringify(t.a11y)} />

    <noscript>
      <div class="pretalx-widget">
        <div class="pretalx-widget-info-message">
          {t.noscript}{' '}
          <a
            target="_blank"
            rel="noopener noreferrer"
            aria-label={`${t.noscriptLink} ${menuT.new_tab}`}
            href="https://pretalx.com/pycones-2026/schedule/"
          >
            {t.noscriptLink}
          </a>
          .
        </div>
      </div>
    </noscript>
  </div>
</section>

<div id="favorite-status" role="status" aria-live="polite" aria-atomic="true" class="sr-only"></div>

<style>
  .schedule-view.hidden {
    display: none;
  }
  #schedule-list-view.filter-favorites-only .schedule-list li:not(.is-favorite) {
    display: none;
  }
  .favorites-filter-btn[aria-pressed='true'] {
    background-color: var(--color-pycon-orange, #fd6837);
    color: #03004b;
    font-weight: 600;
    border-color: var(--color-pycon-orange, #fd6837);
  }
  .favorites-filter-btn[aria-pressed='true'] svg {
    fill: currentColor;
    stroke: currentColor;
  }
</style>

<script is:inline src="https://pretalx.com/pycones-2026/widgets/schedule.js"></script>

<script is:inline>
  ;(function () {
    // === View toggle (list <-> grid) ===
    ;(function () {
      const STORAGE_KEY = 'pycones-schedule-view'
      const radios = document.querySelectorAll('input[name="schedule-view"]')
      const views = document.querySelectorAll('.schedule-view')

      function applyView(value) {
        views.forEach((v) => {
          if (v.getAttribute('data-view') === value) {
            v.classList.remove('hidden')
          } else {
            v.classList.add('hidden')
          }
        })
        try {
          localStorage.setItem(STORAGE_KEY, value)
        } catch (e) {}
        document.dispatchEvent(new CustomEvent('pycones:view-changed', { detail: { value } }))
      }

      radios.forEach((radio) => {
        radio.addEventListener('change', (e) => {
          applyView(e.target.value)
        })
      })

      try {
        const saved = localStorage.getItem(STORAGE_KEY)
        // Only restore the saved view if it matches the HTML default. Legacy
        // values (e.g. 'list' from when list was the default) are ignored so
        // the page always opens with the current default and there's no jump
        // from a stale saved value.
        const defaultChecked = document.querySelector('input[name="schedule-view"]:checked')
        const defaultValue = defaultChecked ? defaultChecked.value : null
        if ((saved === 'list' || saved === 'grid') && saved === defaultValue) {
          applyView(saved)
        }
      } catch (e) {}
    })()

    // === Favorites sync (shared with the Pretalx widget) ===
    // The widget persists favourites under `pycones-2026_favs` as a JSON
    // array of session codes. We read/write the same key so toggling in
    // the list is reflected in the widget (and vice-versa, next time the
    // widget re-reads on mount).
    ;(function () {
      const FAV_KEY = 'pycones-2026_favs'

      function readFavs() {
        try {
          const raw = localStorage.getItem(FAV_KEY)
          if (!raw) return []
          const arr = JSON.parse(raw)
          return Array.isArray(arr) ? arr.filter((c) => typeof c === 'string') : []
        } catch (e) {
          return []
        }
      }

      function writeFavs(arr) {
        try {
          localStorage.setItem(FAV_KEY, JSON.stringify(arr))
        } catch (e) {}
      }

      function syncFavorites() {
        const favs = new Set(readFavs())
        document.querySelectorAll('.favorite-btn').forEach((btn) => {
          const code = btn.getAttribute('data-session-code')
          if (!code) return
          const isFav = favs.has(code)
          btn.setAttribute('aria-pressed', isFav ? 'true' : 'false')
          const li = btn.closest('li')
          if (li) li.classList.toggle('is-favorite', isFav)
        })
        updateFavoritesCount()
        updateEmptyState()
      }

      function updateFavoritesCount() {
        const count = readFavs().length
        document.querySelectorAll('[data-favorites-count]').forEach((el) => {
          el.textContent = String(count)
        })
      }

      function updateEmptyState() {
        const empty = document.querySelector('[data-favorites-empty]')
        const listView = document.getElementById('schedule-list-view')
        if (!empty || !listView) return
        const filterActive = listView.classList.contains('filter-favorites-only')
        const count = readFavs().length
        empty.hidden = !(filterActive && count === 0)
      }

      // Click handler: toggle, persist, update visual state and announce
      document.addEventListener('click', (e) => {
        const btn = e.target.closest && e.target.closest('.favorite-btn')
        if (!btn) return
        e.preventDefault()
        const code = btn.getAttribute('data-session-code')
        if (!code) return
        const favs = readFavs()
        const idx = favs.indexOf(code)
        let added
        if (idx >= 0) {
          favs.splice(idx, 1)
          added = false
        } else {
          favs.push(code)
          added = true
        }
        writeFavs(favs)
        syncFavorites()
        // Announce the state change via the live region. We clear it first
        // so identical messages (e.g. clicking the same button twice) are
        // re-announced by screen readers.
        const status = document.getElementById('favorite-status')
        if (status) {
          const message = added ? btn.dataset.addedMessage : btn.dataset.removedMessage
          status.textContent = ''
          // Force a reflow so the new text triggers the live region reliably
          void status.offsetWidth
          status.textContent = message || ''
        }
      })

      // Re-sync when the user switches to the list view (widget may have
      // mutated localStorage in the same session).
      document.addEventListener('pycones:view-changed', syncFavorites)

      // Re-sync on cross-tab/window changes
      window.addEventListener('storage', (e) => {
        if (e.key === FAV_KEY) syncFavorites()
      })

      // Filter button: show only favourited sessions
      const filterBtn = document.querySelector('[data-filter-favorites]')
      if (filterBtn) {
        filterBtn.addEventListener('click', () => {
          const pressed = filterBtn.getAttribute('aria-pressed') === 'true'
          filterBtn.setAttribute('aria-pressed', pressed ? 'false' : 'true')
          const listView = document.getElementById('schedule-list-view')
          if (listView) listView.classList.toggle('filter-favorites-only', !pressed)
          updateEmptyState()
        })
      }

      // Initial render
      syncFavorites()
    })()

    // === Pretalx widget a11y enhancements (for the grid view) ===
    ;(function () {
      function getI18n() {
        const el = document.getElementById('schedule-i18n')
        if (!el) return null
        try {
          return JSON.parse(el.textContent)
        } catch (e) {
          return null
        }
      }
      const i18n = getI18n() || {}

      const CSS_FIX = `
        #filter-bottom-sheet-dialog,
        #filter-bottom-sheet-dialog .dialog-inner {
          background: #fff !important;
          color: #0d0f10 !important;
        }
        .sr-only {
          position: absolute;
          width: 1px;
          height: 1px;
          padding: 0;
          margin: -1px;
          overflow: hidden;
          clip: rect(0, 0, 0, 0);
          white-space: nowrap;
          border: 0;
        }
      `

      function getWidget() {
        return document.querySelector('pretalx-schedule')
      }

      function $inWidget(selector) {
        const w = getWidget()
        if (!w) return null
        if (typeof w.querySelector === 'function') {
          const fromLight = w.querySelector(selector)
          if (fromLight) return fromLight
        }
        if (w.shadowRoot && typeof w.shadowRoot.querySelector === 'function') {
          return w.shadowRoot.querySelector(selector)
        }
        return null
      }

      function $allInWidget(selector) {
        const w = getWidget()
        if (!w) return []
        const out = []
        if (typeof w.querySelectorAll === 'function') {
          out.push(...w.querySelectorAll(selector))
        }
        if (w.shadowRoot && typeof w.shadowRoot.querySelectorAll === 'function') {
          out.push(...w.shadowRoot.querySelectorAll(selector))
        }
        return out
      }

      function injectStyles() {
        const w = getWidget()
        if (!w || !w.shadowRoot) return
        if (w.shadowRoot.querySelector('#pycones-dialog-fix')) return
        const style = document.createElement('style')
        style.id = 'pycones-dialog-fix'
        style.textContent = CSS_FIX
        w.shadowRoot.appendChild(style)
      }

      function isDialogOpen(dlg) {
        if (!dlg) return false
        if (dlg.tagName === 'DIALOG') return dlg.hasAttribute('open')
        return dlg.classList.contains('is-open') || getComputedStyle(dlg).display !== 'none'
      }

      function reinforceDialog() {
        const dlg = $inWidget('#filter-bottom-sheet-dialog, .filter-bottom-sheet')
        if (!dlg || dlg.dataset.a11yFixed) return
        dlg.setAttribute('aria-modal', 'true')
        dlg.setAttribute('role', 'dialog')
        const heading = dlg.querySelector('h1, h2, h3, h4')
        if (heading) {
          if (!heading.id) heading.id = 'pretalx-filters-heading'
          dlg.setAttribute('aria-labelledby', heading.id)
        }
        const closeBtn = dlg.querySelector('button.close-button')
        if (closeBtn && !closeBtn.getAttribute('aria-label')) {
          closeBtn.setAttribute('aria-label', i18n.closeFilters || 'Close filters')
        }
        dlg.dataset.a11yFixed = '1'
      }

      function injectInputLabels() {
        const search = $inWidget('input.search-input, input[type="search"]')
        if (search && !search.id) {
          search.id = 'pretalx-search'
          const l = document.createElement('label')
          l.setAttribute('for', 'pretalx-search')
          l.className = 'sr-only'
          l.textContent = i18n.searchLabel || 'Search sessions'
          if (search.parentNode) search.parentNode.insertBefore(l, search)
        }
        const tz = $inWidget('select[name="timezone"]')
        if (tz && !tz.id) {
          tz.id = 'pretalx-timezone'
          const l = document.createElement('label')
          l.setAttribute('for', 'pretalx-timezone')
          l.className = 'sr-only'
          l.textContent = i18n.timezoneLabel || 'Timezone'
          if (tz.parentNode) tz.parentNode.insertBefore(l, tz)
        }
      }

      function updateLiveStatus() {
        const status = document.getElementById('schedule-status')
        if (!status || !i18n.statusTemplate) return
        const sessions = $allInWidget('.pretalx-session, [class*="pretalx-session"]:not([class*="session-"])')
        if (sessions.length === 0) {
          status.textContent = i18n.statusEmpty || ''
        } else {
          status.textContent = i18n.statusTemplate(sessions.length)
        }
      }

      function observeSchedule() {
        const w = getWidget()
        if (!w || w.dataset.a11yObserver) return
        w.dataset.a11yObserver = '1'

        const targets = [w]
        if (w.shadowRoot) targets.push(w.shadowRoot)

        const statusMo = new MutationObserver(function () {
          clearTimeout(w._statusTimer)
          w._statusTimer = setTimeout(updateLiveStatus, 250)
        })
        targets.forEach(function (t) {
          statusMo.observe(t, { childList: true, subtree: true })
        })
        updateLiveStatus()

        const dlg = $inWidget('#filter-bottom-sheet-dialog, .filter-bottom-sheet')
        if (dlg && !dlg.dataset.a11yCloseObserver) {
          dlg.dataset.a11yCloseObserver = '1'
          let wasOpen = isDialogOpen(dlg)
          const dlgMo = new MutationObserver(function () {
            const isOpen = isDialogOpen(dlg)
            if (wasOpen && !isOpen && w._lastTrigger && document.contains(w._lastTrigger)) {
              try {
                w._lastTrigger.focus()
              } catch (e) {}
              w._lastTrigger = null
            }
            wasOpen = isOpen
          })
          dlgMo.observe(dlg, {
            attributes: true,
            attributeFilter: ['open', 'style', 'class'],
            subtree: false,
          })
        }
      }

      function captureFilterTrigger() {
        document.addEventListener(
          'click',
          function (e) {
            const target = e.target.closest && e.target.closest('button, a')
            if (!target) return
            const aria = (target.getAttribute('aria-label') || '').toLowerCase()
            const text = (target.textContent || '').toLowerCase()
            if (aria.includes('filter') || aria.includes('filtro') || text.includes('filtro')) {
              const w = getWidget()
              if (w) w._lastTrigger = target
            }
          },
          true,
        )
      }

      function setupModality() {
        if (document.body.getAttribute('modality')) return
        const setMode = function (mod) {
          document.body.setAttribute('modality', mod)
        }
        setMode('pointer')
        window.addEventListener('keydown', function (e) {
          if (e.key === 'Tab') setMode('keyboard')
        })
        window.addEventListener('pointerdown', function () {
          setMode('pointer')
        })
      }

      function boot() {
        setupModality()
        injectStyles()
        reinforceDialog()
        injectInputLabels()
        observeSchedule()
        captureFilterTrigger()
      }

      function ready() {
        const w = getWidget()
        if (!w) return
        if (
          typeof w.updateComplete !== 'undefined' &&
          w.updateComplete &&
          typeof w.updateComplete.then === 'function'
        ) {
          w.updateComplete.then(boot)
        } else if (typeof customElements !== 'undefined') {
          customElements.whenDefined('pretalx-schedule').then(boot)
        } else {
          boot()
        }
      }

      if (document.readyState === 'loading') {
        document.addEventListener('DOMContentLoaded', ready)
      } else {
        ready()
      }

      document.addEventListener('astro:page-load', ready)
      new MutationObserver(function () {
        if (getWidget() && !document.body.dataset.a11yBooted) {
          document.body.dataset.a11yBooted = '1'
          ready()
        }
      }).observe(document.body, { childList: true, subtree: true })
    })()
  })()
</script>
