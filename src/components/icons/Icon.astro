---
import type { IconProps } from '../../lib/icons/types'
import { IconSizes } from '../../lib/icons/types'
import { getIconMapping } from '../../lib/icons/mappings/index'
import { CircleAlert } from '@lucide/astro'

interface Props extends IconProps {}

const {
  name,
  size = 'md',
  color = 'currentColor',
  className = '',
  'aria-label': ariaLabel,
  'aria-hidden': ariaHidden = false,
  ...rest
} = Astro.props

// Get the mapped icon or fallback
const { icon: LucideIconComponent, svg, fallback } = getIconMapping(name)

// Build CSS classes
const sizeClasses = IconSizes[size]
const colorClasses = color.startsWith('#') || color.startsWith('rgb') || color.startsWith('hsl') ? '' : color

const classes = [sizeClasses, colorClasses, className, 'inline-block flex-shrink-0'].filter(Boolean).join(' ')

// Build style object for CSS color values
const style = color.startsWith('#') || color.startsWith('rgb') || color.startsWith('hsl') ? { color } : {}

// Log missing mappings in development
if (!LucideIconComponent && !svg && !fallback) {
  try {
    if (typeof window === 'undefined' || (globalThis as any).__DEV__ !== false) {
      console.warn(`[Icon] No mapping found for icon "${name}". Using fallback.`)
    }
  } catch {
    // Silent fallback if environment detection fails
  }
}
---

{
  svg ? (
    <svg
      xmlns="http://www.w3.org/2000/svg"
      viewBox="0 0 24 24"
      class={classes}
      style={style}
      aria-label={ariaHidden ? undefined : ariaLabel}
      aria-hidden={ariaHidden ? 'true' : undefined}
      focusable="false"
      set:html={svg}
      {...rest}
    />
  ) : LucideIconComponent ? (
    <LucideIconComponent
      class={classes}
      style={style}
      aria-label={ariaHidden ? undefined : ariaLabel}
      aria-hidden={ariaHidden ? 'true' : undefined}
      focusable="false"
      {...rest}
    />
  ) : fallback ? (
    <span
      class={`${sizeClasses} ${className} inline-flex items-center justify-center`}
      style={style}
      aria-label={ariaHidden ? undefined : ariaLabel}
      aria-hidden={ariaHidden ? 'true' : undefined}
      {...rest}
    >
      {fallback}
    </span>
  ) : (
    <CircleAlert
      class={classes}
      style={style}
      aria-label={ariaHidden ? undefined : ariaLabel || `Unknown icon: ${name}`}
      aria-hidden={ariaHidden ? 'true' : undefined}
      focusable="false"
      {...rest}
    />
  )
}
