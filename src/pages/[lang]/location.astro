---
import Layout from '../../layouts/Layout.astro'
import LocationPage from '../../components/LocationPage.astro'

export function getStaticPaths() {
  return [{ params: { lang: 'es' } }, { params: { lang: 'en' } }, { params: { lang: 'ca' } }]
}

const { lang } = Astro.params

const titles = {
  es: 'Localización | PyConES 2026',
  en: 'Location | PyConES 2026',
  ca: 'Localització | PyConES 2026',
}

const title = titles[(lang || 'es') as keyof typeof titles]
---

<Layout title={title}>
  <div class="location-page-wrapper min-h-screen w-full absolute top-0 left-0 z-10 overflow-x-hidden pt-24">
    <div class="container mx-auto px-4 md:px-8">
      <LocationPage lang={lang || 'es'} />
    </div>
  </div>
</Layout>

<style>
  .location-page-wrapper {
    background: radial-gradient(circle at 50% -20%, rgba(255, 130, 0, 0.05) 0%, transparent 50%),
                radial-gradient(circle at 0% 100%, rgba(247, 37, 133, 0.05) 0%, transparent 50%);
  }
</style>
